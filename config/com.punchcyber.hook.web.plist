<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.punchcyber.hook.web</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>HOOK_REPO_PATH/scripts/start-web.sh</string>
        <string>--api</string>
    </array>
    <key>KeepAlive</key>
    <true/>
    <key>RunAtLoad</key>
    <true/>
    <key>EnvironmentVariables</key>
    <dict>
        <key>HOOK_DIR</key>
        <string>HOOK_REPO_PATH</string>
        <key>PATH</key>
        <string>/usr/local/bin:/usr/bin:/bin:/opt/homebrew/bin</string>
    </dict>
    <key>StandardOutPath</key>
    <string>HOOK_LOG_PATH/web-stdout.log</string>
    <key>StandardErrorPath</key>
    <string>HOOK_LOG_PATH/web-stderr.log</string>
</dict>
</plist>
