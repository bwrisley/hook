{
  "meta": {
    "lastTouchedVersion": "2026.2.26",
    "lastTouchedAt": "2026-03-01T00:00:00Z"
  },
  "env": {
    "VT_API_KEY": "YOUR_VIRUSTOTAL_API_KEY",
    "CENSYS_API_ID": "YOUR_CENSYS_API_ID",
    "CENSYS_API_SECRET": "YOUR_CENSYS_API_SECRET",
    "ABUSEIPDB_API_KEY": "YOUR_ABUSEIPDB_API_KEY",
    "shellEnv": {
      "enabled": true
    },
    "HOOK_DIR": "HOOK_REPO_PATH"
  },
  "tools": {
    "profile": "full",
    "exec": {
      "backgroundMs": 30000,
      "timeoutSec": 180
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openai/gpt-4.1"
      },
      "workspace": "~/.openclaw/workspace",
      "maxConcurrent": 2,
      "subagents": {
        "maxConcurrent": 3,
        "maxSpawnDepth": 1,
        "maxChildrenPerAgent": 5,
        "runTimeoutSeconds": 300,
        "archiveAfterMinutes": 60
      }
    },
    "list": [
      {
        "id": "coordinator",
        "default": true,
        "workspace": "HOOK_REPO_PATH/workspaces/coordinator",
        "model": {
          "primary": "openai/gpt-4.1"
        },
        "subagents": {
          "allowAgents": [
            "triage-analyst",
            "osint-researcher",
            "incident-responder",
            "threat-intel",
            "report-writer",
            "log-querier"
          ]
        }
      },
      {
        "id": "triage-analyst",
        "workspace": "HOOK_REPO_PATH/workspaces/triage-analyst",
        "model": {
          "primary": "openai/gpt-4.1"
        }
      },
      {
        "id": "osint-researcher",
        "workspace": "HOOK_REPO_PATH/workspaces/osint-researcher",
        "model": {
          "primary": "openai/gpt-4.1"
        }
      },
      {
        "id": "incident-responder",
        "workspace": "HOOK_REPO_PATH/workspaces/incident-responder",
        "model": {
          "primary": "openai/gpt-5"
        }
      },
      {
        "id": "threat-intel",
        "workspace": "HOOK_REPO_PATH/workspaces/threat-intel",
        "model": {
          "primary": "openai/gpt-5"
        }
      },
      {
        "id": "report-writer",
        "workspace": "HOOK_REPO_PATH/workspaces/report-writer",
        "model": {
          "primary": "openai/gpt-4.1"
        }
      },
      {
        "id": "log-querier",
        "workspace": "HOOK_REPO_PATH/workspaces/log-querier",
        "model": {
          "primary": "openai/gpt-4.1"
        }
      }
    ]
  },
  "bindings": [
    {
      "agentId": "coordinator",
      "match": {
        "channel": "slack"
      }
    }
  ],
  "messages": {
    "ackReactionScope": "all"
  },
  "session": {},
  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "session-memory": {},
        "command-logger": {}
      }
    }
  },
  "channels": {
    "slack": {
      "mode": "socket",
      "enabled": true,
      "botToken": "xoxb-YOUR-BOT-TOKEN",
      "appToken": "xapp-YOUR-APP-TOKEN",
      "nativeStreaming": false,
      "channels": {
        "HOOK_CHANNEL_NAME": {
          "allow": true
        }
      }
    }
  },
  "gateway": {
    "port": 18789,
    "mode": "local",
    "controlUi": {
      "enabled": true
    }
  },
  "plugins": {
    "entries": {
      "slack": {
        "enabled": true
      }
    }
  }
}