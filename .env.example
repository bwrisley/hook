# Shadowbox Environment Configuration
# Copy this file: cp .env.example .env
# Fill in your API keys below.

# OpenAI (powers agent LLMs: gpt-4.1, gpt-5)
OPENAI_API_KEY=

# VirusTotal (IOC enrichment - free tier)
VT_API_KEY=

# Censys (IP/host enrichment - free tier)
CENSYS_API_ID=
CENSYS_API_SECRET=

# AbuseIPDB (IP abuse reports - free tier)
ABUSEIPDB_API_KEY=

# AlienVault OTX (community threat intel - free)
OTX_API_KEY=

# Shodan (internet-wide scanning - free tier)
SHODAN_API_KEY=

# Slack (optional - Socket Mode)
# SLACK_BOT_TOKEN=xoxb-
# SLACK_APP_TOKEN=xapp-
# SLACK_CHANNEL=hook

# Database (optional - defaults to SQLite)
# DATABASE_URL=postgresql://shadowbox:password@localhost:5432/shadowbox

# Ollama (optional - defaults to localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434

# OpenSearch (optional - for log-querier agent)
# HOOK_OPENSEARCH_HOST=
# HOOK_OPENSEARCH_PORT=9200
# HOOK_OPENSEARCH_USER=
# HOOK_OPENSEARCH_PASS=
